{
  "name": "peermesh-desktop",
  "version": "1.0.8",
  "description": "PeerMesh Desktop — Share your connection from the system tray",
  "author": "PeerMesh",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win --x64",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux --x64",
    "test": "node node_modules/@playwright/test/cli.js test"
  },
  "build": {
    "appId": "com.peermesh.desktop",
    "productName": "PeerMesh",
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Network"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "runAfterFinish": true,
      "createDesktopShortcut": false,
      "include": "assets/installer.nsh"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "playwright-core": "^1.44.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "electron": "^33.0.0",
    "electron-builder": "^24.0.0"
  }
}